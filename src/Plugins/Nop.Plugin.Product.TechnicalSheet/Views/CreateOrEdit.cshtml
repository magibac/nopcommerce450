@model Nop.Plugin.Product.TechnicalSheet.Models.ProductTechnicalSheetModel

@{

    Layout = "_AdminLayout";
    
    var title = Model.Id > 0 ? T("Admin.ProductTechnicalSheet.EditPage").Text : T("Admin.ProductTechnicalSheet.Create").Text;
    ViewBag.PageTitle = title;
}

<form asp-action="CreateOrEdit" method="post">
    <div asp-validation-summary="All"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ProductId" />

    <div class="content-header clearfix">
        <h1 class="float-left">
            @title
            <small>
                <i class="fas fa-arrow-circle-left"></i>
                <a asp-action="Edit" asp-controller="Product" asp-route-id="@Model.ProductId">@T("Admin.ProductTechnicalSheet.BackToList")</a>
            </small>
        </h1>
        <div class="float-right">
            <button type="submit" name="save" class="btn btn-primary">
                <i class="far fa-save"></i>
                @T("Admin.ProductTechnicalSheet.Save")
            </button>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <div class="form-horizontal">
                <div class="cards-group">
                    <div class="card card-default">
                        <div class="card-body">
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="Title" />
                                </div>
                                <div class="col-md-9">
                                    <nop-editor asp-for="Title" asp-required="true" />
                                    <span asp-validation-for="Title"></span>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="TechnicalCode" />
                                </div>
                                <div class="col-md-9">
                                    <nop-editor asp-for="TechnicalCode" />
                                    <span asp-validation-for="TechnicalCode"></span>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="Description" />
                                </div>
                                <div class="col-md-9">
                                    <nop-editor asp-for="Description" />
                                    <span asp-validation-for="Description"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</form>