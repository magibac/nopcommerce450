@model ProductTechnicalSheetSearchModel

@{
    ViewBag.PageTitle = T("Admin.ProductTechnicalSheet.List").Text;
    NopHtml.SetActiveMenuItemSystemName("Product.TechnicalSheet");
}

<div class="content-header clearfix">
    <h1 class="float-left">
        @T("Admin.ProductTechnicalSheet.List")
    </h1>
    <div class="float-right">
        <a class="btn btn-primary"
           href="@Url.Action("CreateOrEdit", new { productId = Model.ProductId })">
            <i class="fas fa-plus-square"></i>
            @T("Admin.ProductTechnicalSheet.AddNew")
        </a>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default">
                    <div class="card-body">
                        @await Html.PartialAsync("Table", new DataTablesModel
                        {
                            Name = "product-technical-sheets-grid",
                            RowIdBasedOnField = nameof(ProductTechnicalSheetModel.Id),
                            UrlRead = new DataUrl("List", "ProductTechnicalSheet", new RouteValueDictionary { [nameof(ProductTechnicalSheetSearchModel.ProductId)] = Model.ProductId }),
                            UrlDelete = new DataUrl("Delete", "ProductTechnicalSheet", null),
                            Length = Model.PageSize,
                            LengthMenu = Model.AvailablePageSizes,
                            ColumnCollection = new List<ColumnProperty>
                            {
                                new ColumnProperty(nameof(ProductTechnicalSheetModel.Title))
                                {
                                    Title = T("Admin.ProductTechnicalSheet.Fields.Title").Text
                                },
                                new ColumnProperty(nameof(ProductTechnicalSheetModel.TechnicalCode))
                                {
                                    Title = T("Admin.ProductTechnicalSheet.Fields.TechnicalCode").Text,
                                    Width = "150"
                                },
                                new ColumnProperty(nameof(ProductTechnicalSheetModel.Description))
                                {
                                    Title = T("Admin.ProductTechnicalSheet.Fields.Description").Text,
                                    Width = "300"
                                },
                                new ColumnProperty(nameof(ProductTechnicalSheetModel.Id))
                                {
                                    Title = T("Admin.Common.Edit").Text,
                                    Width = "100",
                                    ClassName = NopColumnClassDefaults.Button,
                                    Render = new RenderButtonEdit(new DataUrl("CreateOrEdit"))
                                },
                                new ColumnProperty(nameof(ProductTechnicalSheetModel.Id))
                                {
                                    Title = T("Admin.Common.Delete").Text,
                                    Width = "100",
                                    ClassName = NopColumnClassDefaults.Button,
                                    Render = new RenderButtonRemove()
                                }
                            }
                        })
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
